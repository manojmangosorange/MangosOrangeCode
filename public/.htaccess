<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical domain and protocol
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.mangosorange\.com$ [NC]
  RewriteRule ^ https://mangosorange.com%{REQUEST_URI} [R=301,L]

  # Redirect legacy/public aliases to canonical routes
  RewriteRule ^home/?$ / [R=301,L,NC]
  RewriteRule ^career/?$ /careers [R=301,L,NC]
  RewriteRule ^staffing-solutions/?$ /staffing [R=301,L,NC]

  # Keep robots and sitemap reachable directly
  RewriteRule ^robots\.txt$ - [L,NC]
  RewriteRule ^sitemap\.xml$ - [L,NC]

  # Serve real files/folders as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Prevent stale HTML after deployment
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Aggressive caching for versioned/static assets
  <FilesMatch "\.(js|css|woff|woff2|png|jpg|jpeg|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Keep sitemap cache short for crawl refresh
  <FilesMatch "sitemap\.xml$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/xml .xml
  AddType text/plain .txt
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
